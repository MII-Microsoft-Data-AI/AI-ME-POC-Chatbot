# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
AZURE_OPENAI_DALLE_DEPLOYMENT_NAME=dall-e-3
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# For FLUX model support:
# Set AZURE_OPENAI_DALLE_DEPLOYMENT_NAME to a value containing "flux" (e.g., "FLUX.2-pro")
# The FLUX endpoint will be automatically derived from AZURE_OPENAI_ENDPOINT
# (e.g., https://your-resource.openai.azure.com -> https://your-resource.services.ai.azure.com)

# Azure Session Pool Configuration for Code Interpreter
AZURE_SESSIONPOOL_ENDPOINT=https://your-region.dynamicsessions.io/subscriptions/your-subscription-id/resourceGroups/your-resource-group/sessionPools/your-session-pool-name

# SearxNG Configuration for Web Search
SEARXNG_URL=https://your-searxng-instance.com

# Azure Blob Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER_NAME=your-container-name

# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-resource.search.windows.net
AZURE_SEARCH_API_KEY=your-azure-search-api-key
AZURE_SEARCH_INDEX_NAME=your-index-name

# Azure Document Intelligence Configuration
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=your-document-intelligence-api-key

# Client Configuration
USE_OPENAI_CLIENT=true

# Application Configuration (base64-encoded JSON)
# Generate this from mock-backend/application.config.sample.json and set it as:
# APPLICATION_CONFIG_JSON_BASE64=<base64-encoded-json>

# Agent Configuration (base64-encoded JSON)
# Generate this from mock-backend/agent.config.sample.json and set it as:
# AGENT_CONFIG_JSON_BASE64=<base64-encoded-json>

# Indexing Configuration (base64-encoded JSON)
# Generate this from mock-backend/indexing.config.sample.json and set it as:
# INDEXING_CONFIG_JSON_BASE64=<base64-encoded-json>
