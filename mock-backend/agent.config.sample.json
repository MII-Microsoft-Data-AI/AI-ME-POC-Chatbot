    "ai_search": {
      "enabled": true,
      "endpoint": "https://your-search.search.windows.net",
      "api_key": "your-search-api-key",
      "index_name": "your-index-name",
      "semantic_config": "main-semantic-config",
      "vector_field": "content_vector",
